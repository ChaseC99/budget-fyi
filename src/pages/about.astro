---
import "../styles/global.css";
import { SiteHeader } from "../components/SiteHeader";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Learn what budget.fyi is, how the income calculator works, and where the budget data comes from."
    />
    <title>About budget.fyi</title>
  </head>
  <body>
    <SiteHeader currentPath="/about" />

    <main class="about">
      <section class="card">
        <p class="eyebrow">About</p>
        <h1>The Budget<br/>For Your Information</h1>
        <p>
          <strong>budget.fyi</strong> is a simple way to explore U.S. federal spending and estimate
          how much of each category is represented by your tax contribution.
        </p>
        <p>
          Enter your income to see a personalized breakdown of how your tax dollars were spent.
        </p>
        <p>
          The numbers are best effort estimates based on data available from the various US government agencies.
          Each item has a source link and description. If you notice any errors or have suggestions for improvement, please reach out using the contact form below.
        </p>
        <div style="display: flex; justify-content: space-between;">
          <a class="inline-link" href="/">Explore the budget</a>
          <p>
            <a
              class="inline-link"
              href="https://github.com/chasec99/budget-fyi"
              target="_blank"
              rel="noreferrer"
            >
              <svg
                width="98"
                height="96"
                viewBox="0 0 98 96"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                focusable="false"
              >
                <g clip-path="url(#github-invertocat-clip)">
                  <path
                    d="M41.4395 69.3848C28.8066 67.8535 19.9062 58.7617 19.9062 46.9902C19.9062 42.2051 21.6289 37.0371 24.5 33.5918C23.2559 30.4336 23.4473 23.7344 24.8828 20.959C28.7109 20.4805 33.8789 22.4902 36.9414 25.2656C40.5781 24.1172 44.4062 23.543 49.0957 23.543C53.7852 23.543 57.6133 24.1172 61.0586 25.1699C64.0254 22.4902 69.2891 20.4805 73.1172 20.959C74.457 23.543 74.6484 30.2422 73.4043 33.4961C76.4668 37.1328 78.0937 42.0137 78.0937 46.9902C78.0937 58.7617 69.1934 67.6621 56.3691 69.2891C59.623 71.3945 61.8242 75.9883 61.8242 81.252L61.8242 91.2051C61.8242 94.0762 64.2168 95.7031 67.0879 94.5547C84.4102 87.9512 98 70.6289 98 49.1914C98 22.1074 75.9883 6.69539e-07 48.9043 4.309e-07C21.8203 1.92261e-07 -1.9479e-07 22.1074 -4.3343e-07 49.1914C-6.20631e-07 70.4375 13.4941 88.0469 31.6777 94.6504C34.2617 95.6074 36.75 93.8848 36.75 91.3008L36.75 83.6445C35.4102 84.2188 33.6875 84.6016 32.1562 84.6016C25.8398 84.6016 22.1074 81.1563 19.4277 74.7441C18.375 72.1602 17.2266 70.6289 15.0254 70.3418C13.877 70.2461 13.4941 69.7676 13.4941 69.1934C13.4941 68.0449 15.4082 67.1836 17.3223 67.1836C20.0977 67.1836 22.4902 68.9063 24.9785 72.4473C26.8926 75.2227 28.9023 76.4668 31.2949 76.4668C33.6875 76.4668 35.2187 75.6055 37.4199 73.4043C39.0469 71.7773 40.291 70.3418 41.4395 69.3848Z"
                    fill="black"
                  ></path>
                </g>
                <defs>
                  <clipPath id="github-invertocat-clip">
                    <rect width="98" height="96" fill="white"></rect>
                  </clipPath>
                </defs>
              </svg>
              Source code
            </a>
          </p>
        </div>
      </section>

      <section aria-label="Contact">
        <section class="card detail-card">
          <p class="eyebrow">Contact</p>
          <h2>Send feedback or get in touch.</h2>
          <p>
            Use the form below for questions, ideas, or bug reports about the project.
          </p>
          <div class="iframe-shell">
            <iframe
              src="https://docs.google.com/forms/d/e/1FAIpQLScWlIhSW6MNR4PLzrJkkJsBY_osC4ZLMZML_jVIC6KUIhrXmA/viewform?embedded=true"
              width="640"
              height="900"
              frameborder="0"
              marginheight="0"
              marginwidth="0"
              title="budget.fyi contact form"
            >
              Loading…
            </iframe>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>

<style>
  .about {
    width: min(100%, 760px);
    margin: 0 auto;
    padding: 16px 16px 48px;
  }

  .card {
    display: grid;
    gap: 18px;
    padding: 28px;
    border: 1px solid #e5e7eb;
    border-radius: 24px;
    background: #ffffff;
  }

  .detail-card {
    align-content: start;
  }

  .eyebrow {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #1d4ed8;
  }

  h1 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
  }

  h2 {
    font-size: 1.5rem;
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  p {
    font-size: 1rem;
    line-height: 1.65;
    color: #374151;
  }

  a {
    color: #1d4ed8;
    font-weight: 600;
    text-decoration: none;
  }

  .inline-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .inline-link svg {
    width: 1rem;
    height: 1rem;
    flex: 0 0 auto;
  }

  a:hover {
    text-decoration: underline;
  }

  .detail-card {
    margin-top: 20px;
  }

  .iframe-shell {
    overflow: hidden;
    border: 1px solid #dbeafe;
    border-radius: 18px;
    background: #eff6ff;
  }

  .iframe-shell iframe {
    display: block;
    width: 100%;
    max-width: 100%;
    min-height: 780px;
    border: 0;
  }

  @media (max-width: 640px) {
    .about {
      padding-inline: 12px;
      padding-bottom: 32px;
    }

    .card {
      padding: 22px 18px;
      border-radius: 20px;
    }
  }
</style>
